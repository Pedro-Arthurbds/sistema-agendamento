generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Barbeiro {
  id        String   @id @default(cuid())
  nome      String
  foto      String?
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now())

  horarios     HorarioFuncionamento[]
  bloqueios    Bloqueio[]
  agendamentos Agendamento[]
}

model HorarioFuncionamento {
  id         String   @id @default(cuid())
  barbeiroId String
  barbeiro   Barbeiro @relation(fields: [barbeiroId], references: [id])
  diaSemana  Int
  horaInicio String
  horaFim    String
  ativo      Boolean  @default(true)
}

model Bloqueio {
  id         String   @id @default(cuid())
  barbeiroId String
  barbeiro   Barbeiro @relation(fields: [barbeiroId], references: [id])
  data       DateTime
  horaInicio String?
  horaFim    String?
  motivo     String?
  criadoEm  DateTime @default(now())
}

model Servico {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  preco       Float
  duracaoMin  Int
  ativo       Boolean  @default(true)
  criadoEm   DateTime @default(now())

  agendamentos Agendamento[]
}

model Cliente {
  id          String   @id @default(cuid())
  nome        String
  whatsapp    String   @unique
  observacoes String?
  criadoEm   DateTime @default(now())

  agendamentos Agendamento[]
}

model Agendamento {
  id               String   @id @default(cuid())
  clienteId        String
  cliente          Cliente  @relation(fields: [clienteId], references: [id])
  barbeiroId       String
  barbeiro         Barbeiro @relation(fields: [barbeiroId], references: [id])
  servicoId        String
  servico          Servico  @relation(fields: [servicoId], references: [id])
  dataHora         DateTime
  status           String   @default("PENDENTE")
  tokenConfirmacao String   @unique @default(cuid())
  expiraEm         DateTime
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt
}

model Admin {
  id       String   @id @default(cuid())
  email    String   @unique
  senha    String
  criadoEm DateTime @default(now())
}